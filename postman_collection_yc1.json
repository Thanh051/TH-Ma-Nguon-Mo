{
  "info": {
    "name": "WebStore LAB 5&6 - Yêu cầu 1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/WebStore/api"
    }
  ],
  "item": [
    {
      "name": "Product - GET list",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/product"
      }
    },
    {
      "name": "Product - GET detail",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/product/detail/1"
      }
    },
    {
      "name": "Product - POST create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sản phẩm test API\",\n  \"price\": 150000,\n  \"stock\": 10,\n  \"category_id\": 1,\n  \"image\": \"test.jpg\",\n  \"description\": \"Thêm bằng Postman\"\n}"
        },
        "url": "{{base_url}}/product/create"
      }
    },
    {
      "name": "Product - PUT update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"iPhone 15 Pro Max Updated\",\n  \"price\": 33000000,\n  \"stock\": 5,\n  \"category_id\": 1,\n  \"image\": \"1779696697_iphone17prm.jpg\",\n  \"description\": \"Cập nhật bằng API PUT\"\n}"
        },
        "url": "{{base_url}}/product/update/1"
      }
    },
    {
      "name": "Product - DELETE",
      "request": { "method": "DELETE", "url": "{{base_url}}/product/delete/7" }
    },
    {
      "name": "Category - GET list",
      "request": { "method": "GET", "url": "{{base_url}}/category" }
    },
    {
      "name": "Category - POST create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Danh mục test\",\n  \"description\": \"Tạo bằng Postman\"\n}" },
        "url": "{{base_url}}/category/create"
      }
    },
    {
      "name": "Category - PUT update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Danh mục cập nhật\",\n  \"description\": \"Cập nhật bằng PUT\"\n}" },
        "url": "{{base_url}}/category/update/1"
      }
    },
    {
      "name": "Cart - GET",
      "request": { "method": "GET", "url": "{{base_url}}/cart" }
    },
    {
      "name": "Cart - POST add",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 2\n}" },
        "url": "{{base_url}}/cart/add"
      }
    },
    {
      "name": "Cart - PUT update",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" },
        "url": "{{base_url}}/cart/update/1"
      }
    },
    {
      "name": "Order - POST create",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"customer_name\": \"Nguyễn Văn A\",\n  \"customer_phone\": \"0901234567\",\n  \"customer_address\": \"TP.HCM\"\n}" },
        "url": "{{base_url}}/order/create"
      }
    },
    {
      "name": "Account - POST login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}" },
        "url": "{{base_url}}/account/login"
      }
    }
  ]
}
